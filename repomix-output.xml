    expect(mockUpdateNodeConfig).not.toHaveBeenCalledWith(
      "set-variable-1",
      expect.objectContaining({
        kind: "setVariable",
        key: "variableName",
        value: "existing",
      })
    )
    expect(
      screen.getByText("Variable name must be unique in this workflow.")
    ).toBeTruthy()
  })
})
